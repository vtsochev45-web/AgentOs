# Required
DATABASE_URL=postgresql://user:password@localhost:5432/agentos
OPENROUTER_API_KEY=sk-or-...

# Optional — override OpenRouter base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional — use OpenAI directly instead of OpenRouter
# OPENAI_API_KEY=sk-...

# Optional — API key to protect endpoints
# OPENCLAW_API_KEY=

# Optional — encryption key for secrets in DB (defaults to DATABASE_URL)
# ENCRYPTION_SECRET=random-32-char-string

# Ports
PORT=8081
# API server always runs on 8080
