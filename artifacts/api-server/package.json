    "pino-http": "^10",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^6.4.17",
    "@types/ssh2": "^1.15.4",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
